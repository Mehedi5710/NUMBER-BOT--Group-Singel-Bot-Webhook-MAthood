# NUMBER BOT Webhook 2.0 configuration
# Copy to `.env` and fill in your real values.

BOT_TOKEN=ENTER_BOT_TOKEN
FORWARDER_BOT_TOKEN=ENTER_FORWARDER_BOT_TOKEN_OR_SAME_AS_BOT_TOKEN
ADMIN_IDS=ENTER_ADMIN_IDS_COMMA_SEPARATED
BOT_NAME=ENTER_BOT_NAME
OTP_GROUP_URL=ENTER_OTP_GROUP_URL
BRANDING_NAME=ENTER_BRAND_NAME
BRANDING_URL=https://t.me/ENTER_BRAND_LINK

DB_NAME=number_panel.db
LOG_DIR=logs
BACKUP_DIR=backups

TELEGRAM_PARSE_MODE=HTML

WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=3232
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=ENTER_WEBHOOK_SECRET_OR_LEAVE_EMPTY
WEBHOOK_WORKERS=4
SEND_WORKERS=8
SEND_DELAY=0.05
GROUP_SEND_WORKERS=8
GROUP_SEND_DELAY=0.02
TELEGRAM_DEBUG_JSON=0
