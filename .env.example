# NUMBER BOT Webhook 2.0 configuration
# Copy this file to `.env` and replace the sample values below.

# Required
BOT_TOKEN=123456789:REPLACE_WITH_YOUR_BOT_TOKEN
ADMIN_IDS=123456789
BOT_NAME=NUMBER BOT

# Optional
FORWARDER_BOT_TOKEN=
OTP_GROUP_URL=
BRANDING_NAME=
BRANDING_URL=
TELEGRAM_PARSE_MODE=HTML

# Database
# SQLite:
#   DB_ENGINE=sqlite
#   DB_NAME=number_panel.db
#
# PostgreSQL:
#   DB_ENGINE=postgresql
#   DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/number_bot
#
# Use this block if you want local PostgreSQL instead of SQLite:
# DB_ENGINE=postgresql
# DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/number_bot
# POSTGRES_USE_POOL=1
# POSTGRES_POOL_MIN_SIZE=1
# POSTGRES_POOL_MAX_SIZE=8
# POSTGRES_CONNECT_TIMEOUT=10
DB_ENGINE=sqlite
DATABASE_URL=
POSTGRES_USE_POOL=1
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=8
POSTGRES_CONNECT_TIMEOUT=10
DB_NAME=number_panel.db

# Paths
LOG_DIR=logs
BACKUP_DIR=backups

# Webhook
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=3232
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
WEBHOOK_WORKERS=4

# Telegram sending workers
SEND_WORKERS=8
SEND_DELAY=0.05
GROUP_SEND_WORKERS=8
GROUP_SEND_DELAY=0.02
BROADCAST_SEND_WORKERS=4
BROADCAST_SEND_DELAY=0.0
TELEGRAM_DEBUG_JSON=0
